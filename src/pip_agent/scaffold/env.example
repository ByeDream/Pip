# --- Anthropic API ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=              # Leave empty for default (api.anthropic.com)

# --- Web Search ---
SEARCH_API_KEY=                  # Tavily API key; leave empty to use DuckDuckGo fallback

# --- WeCom (企业微信智能机器人) ---
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# --- Debug ---
VERBOSE=true
PROFILER_ENABLED=false

# --- Per-Agent Settings ---
# MODEL, MAX_TOKENS, COMPACT_THRESHOLD, and COMPACT_MICRO_AGE are now
# configured per-agent in .pip/agents/*.md (YAML frontmatter).
# See .pip/agents/pip-boy.md for the default agent configuration.
